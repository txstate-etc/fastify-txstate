{
  "name": "fastify-txstate",
  "version": "4.0.0",
  "description": "A small wrapper for fastify providing a set of common conventions & utility functions we use.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "types": "./lib/index.d.ts",
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "rm -rf lib && tsc",
    "test": "./test.sh",
    "nodetest": "node --experimental-transform-types --no-warnings --test test/**/*.ts",
    "testserver": "node --experimental-transform-types --no-warnings testserver/index.ts",
    "lint": "eslint src test testserver"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@fastify/type-provider-json-schema-to-ts": "^5.0.0",
    "@txstate-mws/fastify-shared": "^1.0.9",
    "ajv": "^8.20.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.0",
    "fastify": "^5.0.0",
    "http-status-codes": "^2.1.4",
    "jose": "^6.0.0",
    "openapi-types": "^12.1.3",
    "pino": "^10.3.1",
    "txstate-utils": "^1.9.5",
    "ua-parser-js": "^2.0.0"
  },
  "devDependencies": {
    "@fastify/multipart": "^10.0.0",
    "@stylistic/eslint-plugin": "^5.0.0",
    "@types/chai": "^5.2.3",
    "@types/node": "^24.0.0",
    "axios": "^1.15.0",
    "chai": "^6.0.0",
    "eslint-config-love": "^153.0.0",
    "json-schema-to-ts": "^3.0.1",
    "typescript": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/txstate-etc/fastify-txstate.git"
  },
  "author": "Nick Wing",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/txstate-etc/fastify-txstate/issues"
  },
  "homepage": "https://github.com/txstate-etc/fastify-txstate#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "lib/**/*"
  ]
}
